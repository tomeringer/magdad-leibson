#define RX_PIN 3

void setup() {
  Serial.begin(115200);
  pinMode(RX_PIN, INPUT);
  Serial.println("Nano Receiver - Raw 8-Bit Mode");
}

void loop() {
  // 1. המתנה לעליית מתח (תחילת פולס הסנכרון)
  while (digitalRead(RX_PIN) == LOW); 

  unsigned long tStart = micros();
  while (digitalRead(RX_PIN) == HIGH); 
  unsigned long syncHigh = micros() - tStart;

  // 2. זיהוי סנכרון (כ-1000 מיקרו-שניות)
  if (syncHigh > 800 && syncHigh < 1200) { 
    
    // ממתינים שהחצי הנמוך של הסנכרון יסתיים
    delayMicroseconds(1000);

    char rawBits[9]; // מערך של תווים כדי שנוכל לשמור '0', '1' או 'E'
    rawBits[8] = '\0'; // סוגר את המחרוזת כדי שנוכל להדפיס אותה בקלות
    
    // 3. קריאת 8 הביטים - בשיטת מנצ'סטר האמיתית!
    for (int i = 0; i <= 7; i++) {
      delayMicroseconds(250); // אמצע החצי הראשון
      int firstHalf = digitalRead(RX_PIN);
      
      delayMicroseconds(500); // אמצע החצי השני
      int secondHalf = digitalRead(RX_PIN);
      
      delayMicroseconds(250); // השלמת הביט

      // הלוגיקה האמיתית של מנצ'סטר
      if (firstHalf == HIGH && secondHalf == LOW) {
        rawBits[i] = '1';  // ירידת מתח = 1
      } 
      else if (firstHalf == LOW && secondHalf == HIGH) {
        rawBits[i] = '0';  // עליית מתח = 0
      } 
      else {
        rawBits[i] = 'E';  // שגיאה! שני החצאים זהים (רעש)
      }
    }
    
    // 4. הדפסת התוצאה
    Serial.println(rawBits);
  }
}
